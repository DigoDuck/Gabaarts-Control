# copie para .env e ajuste a senha — nunca commitar o .env (já está no .gitignore)
POSTGRES_DB=gabaarts
POSTGRES_USER=gabaarts
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
SECRET_KEY=dev-only-change-me
# Origem do Vite local; este já é o default em config.settings.dev.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Railway usa DATABASE_URL; no Compose local, mantenha as variáveis POSTGRES_* acima.
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco
